<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutAlarmRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_header_gradient"
    android:padding="24dp">

    <!-- Icon báo thức -->
    <TextView
        android:id="@+id/tvAlarmIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏰"
        android:textSize="80sp"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tên Kíp trực -->
    <TextView
        android:id="@+id/tvAlarmCrew"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kíp A"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvAlarmIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tên Ca trực -->
    <TextView
        android:id="@+id/tvAlarmShift"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="☀️ Ca Ngày"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAlarmCrew"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Nội dung thông báo nhắc nhở -->
    <TextView
        android:id="@+id/tvAlarmMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Hãy dán cam hoặc mở app MDM"
        android:textColor="#EEFFFFFF"
        android:textSize="20sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvAlarmShift"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Layout chứa các nút điều khiển -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nút Dừng Báo Thức -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopAlarm"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="DỪNG BÁO THỨC"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="32dp"
            app:backgroundTint="#EF4444"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:rippleColor="#40FFFFFF" />

        <!-- Nút Nhắc Lại -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSnoozeAlarm"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="NHẮC LẠI SAU 10 PHÚT"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="28dp"
            android:layout_marginHorizontal="32dp"
            app:rippleColor="#20FFFFFF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
